# ======================
# Application Settings
# ======================
APP_NAME=Grafana PDF Reporter
DEBUG=true
LOG_LEVEL=DEBUG

# ======================
# PostgreSQL Database
# ======================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=grafana_reporter
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=grafana_reporter

# ======================
# JWT Authentication
# ======================
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ======================
# Grafana Connection
# ======================
GRAFANA_URL=http://your-grafana-host:3000
GRAFANA_API_KEY=your-grafana-service-account-token
GRAFANA_TIMEOUT=30

# ======================
# CORS (JSON list of origins)
# ======================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
