{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      1,
      "always",
      [
        "backend",
        "frontend",
        "api",
        "auth",
        "pdf",
        "grafana",
        "db",
        "docker",
        "helm",
        "ci",
        "deps",
        "i18n",
        "pwa",
        "tests"
      ]
    ],
    "subject-case": [0],
    "body-max-line-length": [0]
  }
}
